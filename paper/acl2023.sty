% acl2023.sty -- Style file for ACL 2023 and compatible NLP conferences
% Minimal version for CodeBrain paper skeleton
%
% Based on ACL/EMNLP formatting requirements:
%   - A4 or Letter paper
%   - Two-column format
%   - Times font
%   - Standard margins

\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{acl2023}[2023/01/01 ACL 2023 style]

% ---- Page layout ----
\RequirePackage[
  letterpaper,
  top=2.5cm,
  bottom=2.5cm,
  left=2cm,
  right=2cm,
  columnsep=0.6cm
]{geometry}

\RequirePackage{multicol}

% ---- Typography ----
\RequirePackage{times}
\RequirePackage{microtype}
\RequirePackage{natbib}

% Use natbib with author-year style
\setcitestyle{authoryear,round,semicolon,aysep={,},yysep={,}}

% ---- Two-column layout ----
\twocolumn

% ---- Title formatting ----
\RequirePackage{titlesec}

\titleformat{\section}
  {\normalfont\large\bfseries}
  {\thesection}{1em}{}

\titleformat{\subsection}
  {\normalfont\normalsize\bfseries}
  {\thesubsection}{1em}{}

\titleformat{\subsubsection}
  {\normalfont\normalsize\itshape}
  {\thesubsubsection}{1em}{}

% ---- Compact spacing ----
\titlespacing*{\section}{0pt}{2.0ex plus 0.5ex minus 0.2ex}{1.0ex plus 0.2ex}
\titlespacing*{\subsection}{0pt}{1.5ex plus 0.3ex minus 0.2ex}{0.8ex plus 0.2ex}
\titlespacing*{\subsubsection}{0pt}{1.0ex plus 0.2ex minus 0.1ex}{0.5ex plus 0.1ex}

% ---- Paragraph formatting ----
\setlength{\parindent}{1em}
\setlength{\parskip}{0pt}

% ---- Abstract ----
\renewenvironment{abstract}{%
  \centerline{\large\bfseries Abstract}%
  \vspace{0.5ex}%
  \begin{quote}\small
}{%
  \end{quote}%
}

% ---- Footnotes ----
\renewcommand{\footnoterule}{%
  \kern-3pt
  \hrule width 0.4\columnwidth
  \kern 2.6pt
}

% ---- Float placement ----
\renewcommand{\topfraction}{0.9}
\renewcommand{\bottomfraction}{0.8}
\renewcommand{\textfraction}{0.1}
\renewcommand{\floatpagefraction}{0.8}

% ---- Hyperref defaults ----
\AtBeginDocument{%
  \hypersetup{
    colorlinks=true,
    linkcolor=blue!60!black,
    citecolor=blue!60!black,
    urlcolor=blue!60!black
  }%
}

\endinput
